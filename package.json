{
  "name": "@sentry/refactor-tasks",
  "version": "0.1.0",
  "private": false,
  "description": "LLM-powered code-convention scanner that reports refactor tasks to Sentry for Seer to fix",
  "keywords": [
    "codemod",
    "convention",
    "lint",
    "refactor",
    "seer",
    "sentry"
  ],
  "homepage": "https://github.com/getsentry/sentry-refactor-tasks",
  "bugs": {
    "url": "https://github.com/getsentry/sentry-refactor-tasks/issues"
  },
  "license": "MIT",
  "author": "Sentry",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getsentry/sentry-refactor-tasks.git"
  },
  "bin": {
    "refactor-tasks": "./src/index.ts"
  },
  "files": [
    "src",
    "repos",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node src/index.ts",
    "check": "tsgo --noEmit",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix ."
  },
  "dependencies": {
    "@sentry/node": "^9.0.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "fast-glob": "^3.3.0",
    "p-limit": "^6.2.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript/native-preview": "latest",
    "oxfmt": "latest",
    "oxlint": "latest",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.30.2"
}
