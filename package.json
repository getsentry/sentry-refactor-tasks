{
  "name": "@sentry/refactor-tasks",
  "version": "0.0.3",
  "private": false,
  "description": "LLM-powered code-convention scanner that reports refactor tasks to Sentry for Seer to fix",
  "keywords": [
    "codemod",
    "convention",
    "lint",
    "refactor",
    "seer",
    "sentry"
  ],
  "homepage": "https://github.com/getsentry/sentry-refactor-tasks",
  "bugs": {
    "url": "https://github.com/getsentry/sentry-refactor-tasks/issues"
  },
  "license": "MIT",
  "author": "Sentry",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getsentry/sentry-refactor-tasks.git"
  },
  "bin": {
    "refactor-tasks": "./lib/index.js"
  },
  "files": [
    "lib",
    "src",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "check": "tsgo --noEmit",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix ."
  },
  "dependencies": {
    "@sentry/node": "10.60.0",
    "chalk": "5.6.2",
    "commander": "15.0.0",
    "fast-glob": "3.3.3",
    "p-limit": "7.3.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@typescript/native-preview": "7.0.0-dev.20260624.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.71.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.30.2"
}
